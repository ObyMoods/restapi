<%- include('partials/header') %>

<style>
    body.verify-page {
        margin: 0;
        padding: 0;
        overflow: hidden;
    }
    
    .verify-wrapper {
        margin-left: 0;
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        background: linear-gradient(135deg, #6c63ff, #3b3b98);
        padding: 20px;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 9999;
    }

    .auth-container {
        max-width: 450px;
        width: 100%;
        background: white;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        overflow: hidden;
    }

    .auth-header {
        background: linear-gradient(135deg, #6c63ff, #3b3b98);
        color: white;
        padding: 40px 30px 30px;
        text-align: center;
    }

    .auth-header i {
        font-size: 50px;
        margin-bottom: 10px;
        display: block;
    }

    .auth-header h2 {
        margin: 10px 0 5px;
        font-size: 24px;
        font-weight: 700;
    }

    .auth-header p {
        margin: 0;
        font-size: 14px;
        opacity: 0.9;
    }

    .auth-body {
        padding: 30px;
        text-align: center;
    }

    .auth-body .icon-big {
        font-size: 80px;
        color: #6c63ff;
        margin-bottom: 20px;
        display: block;
    }

    .auth-body h3 {
        color: #2d3436;
        margin-bottom: 10px;
        font-size: 20px;
    }

    .auth-body p {
        color: #636e72;
        font-size: 15px;
        line-height: 1.6;
        margin-bottom: 20px;
    }

    .input-group {
        margin-bottom: 20px;
        position: relative;
    }

    .input-group input {
        width: 100%;
        padding: 14px 15px;
        border: 2px solid #e1e5e9;
        border-radius: 10px;
        font-size: 18px;
        text-align: center;
        letter-spacing: 4px;
        transition: 0.3s;
        background: #f8f9fa;
        outline: none;
        color: #333;
    }

    .input-group input:focus {
        border-color: #6c63ff;
        background: white;
        box-shadow: 0 0 0 4px rgba(108, 99, 255, 0.1);
    }

    .btn-verify {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #6c63ff, #3b3b98);
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.3s;
    }

    .btn-verify:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(108, 99, 255, 0.3);
    }

    .btn-secondary {
        width: 100%;
        padding: 14px;
        background: #dfe6e9;
        color: #2d3436;
        border: none;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.3s;
        margin-top: 10px;
        text-decoration: none;
        display: inline-block;
        box-sizing: border-box;
    }

    .btn-secondary:hover {
        background: #b2bec3;
    }

    .auth-footer {
        text-align: center;
        padding: 0 30px 30px;
    }

    .auth-footer a {
        color: #6c63ff;
        text-decoration: none;
        font-weight: 600;
    }

    .error-msg {
        background: #fee;
        color: #d63031;
        padding: 12px 15px;
        border-radius: 10px;
        margin-bottom: 20px;
        font-size: 14px;
        text-align: center;
        border: 1px solid #fab1a0;
    }

    @media (max-width: 480px) {
        .auth-container {
            margin: 20px;
        }
        .auth-header {
            padding: 30px 20px 25px;
        }
        .auth-body {
            padding: 20px;
        }
        .auth-footer {
            padding: 0 20px 20px;
        }
    }
</style>

<div class="verify-wrapper">
    <div class="auth-container">
        <div class="auth-header">
            <i class="fas fa-lock"></i>
            <h2>Verifikasi Akun</h2>
            <p>Masukkan kode OTP yang dikirim ke email Anda</p>
        </div>
        
        <div class="auth-body">
            <% if (error) { %>
                <div class="error-msg">
                    <i class="fas fa-exclamation-circle"></i> <%= error %>
                </div>
            <% } %>
            
            <i class="fas fa-key icon-big"></i>
            
            <h3>Masukkan Kode OTP</h3>
            <p>
                Kode verifikasi telah dikirim ke <strong style="color:#6c63ff;"><%= email %></strong>
            </p>
            
            <form action="/verify-otp" method="POST">
                <input type="hidden" name="email" value="<%= email %>">
                <div class="input-group">
                    <input type="text" name="otp" placeholder="6 digit kode OTP" maxlength="6" required>
                </div>
                <button type="submit" class="btn-verify">
                    <i class="fas fa-check-circle"></i> Verifikasi
                </button>
            </form>
            
            <form action="/resend-otp" method="POST" style="margin-top: 10px;">
                <input type="hidden" name="email" value="<%= email %>">
                <button type="submit" class="btn-secondary">
                    <i class="fas fa-redo"></i> Kirim Ulang OTP
                </button>
            </form>
        </div>
        
        <div class="auth-footer">
            <p>Butuh bantuan? <a href="#">Hubungi Support</a></p>
        </div>
    </div>
</div>

<%- include('partials/footer') %>