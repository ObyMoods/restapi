<%- include('partials/header') %>

<style>
    .hero {
        text-align: center;
        padding: 50px 20px 30px;
        background: linear-gradient(145deg, #161b22, #0d1117);
        border-radius: 16px;
        margin-bottom: 30px;
        border: 1px solid #30363d;
    }
    .hero h1 {
        font-size: 32px;
        color: #f0f6fc;
        margin-bottom: 10px;
    }
    .hero h1 span { color: #58a6ff; }
    .hero p {
        color: #8b949e;
        font-size: 16px;
        max-width: 600px;
        margin: 0 auto 20px;
    }
    .hero-buttons {
        display: flex;
        justify-content: center;
        gap: 15px;
        flex-wrap: wrap;
    }
    .btn-primary-hero {
        background: #6c63ff;
        color: white;
        padding: 10px 30px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.2s;
    }
    .btn-primary-hero:hover { background: #5a52d5; }
    .btn-secondary-hero {
        background: #30363d;
        color: #c9d1d9;
        padding: 10px 30px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.2s;
    }
    .btn-secondary-hero:hover { background: #484f58; }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }
    .stat-card {
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        transition: 0.2s;
    }
    .stat-card:hover { border-color: #58a6ff; }
    .stat-card .icon {
        font-size: 30px;
        color: #6c63ff;
        margin-bottom: 10px;
    }
    .stat-card .number {
        font-size: 28px;
        font-weight: bold;
        color: #f0f6fc;
    }
    .stat-card .label {
        color: #8b949e;
        font-size: 14px;
        margin-top: 5px;
    }

    .info-bar {
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: 8px;
        padding: 15px 20px;
        margin: 20px 0;
        font-size: 14px;
        color: #8b949e;
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        justify-content: center;
    }
    .info-bar strong {
        color: #f0f6fc;
    }
    .info-bar i {
        color: #58a6ff;
        margin-right: 5px;
    }

    .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-top: 30px;
    }
    .feature-card {
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: 12px;
        padding: 25px;
        text-align: center;
    }
    .feature-card i {
        font-size: 40px;
        color: #58a6ff;
        margin-bottom: 15px;
    }
    .feature-card h3 {
        color: #f0f6fc;
        margin-bottom: 8px;
    }
    .feature-card p {
        color: #8b949e;
        font-size: 14px;
    }

    .profile-container {
        max-width: 600px;
        margin: 0 auto;
    }
    .profile-header {
        text-align: center;
        margin-bottom: 30px;
    }
    .profile-avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 4px solid #6c63ff;
        margin: 0 auto 15px;
        background: #30363d;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 50px;
        color: #6c63ff;
    }
    .profile-name {
        font-size: 24px;
        color: #f0f6fc;
        font-weight: bold;
    }
    .profile-email {
        color: #8b949e;
        font-size: 16px;
    }

    body.light-theme {
        background: #f0f2f5;
        color: #1a1a2e;
    }
    body.light-theme .hero {
        background: white;
        border-color: #e1e5e9;
    }
    body.light-theme .hero h1 {
        color: #1a1a2e;
    }
    body.light-theme .stat-card {
        background: white;
        border-color: #e1e5e9;
    }
    body.light-theme .stat-card .number {
        color: #1a1a2e;
    }
    body.light-theme .info-bar {
        background: white;
        border-color: #e1e5e9;
    }
    body.light-theme .info-bar strong {
        color: #1a1a2e;
    }
    body.light-theme .feature-card {
        background: white;
        border-color: #e1e5e9;
    }
    body.light-theme .feature-card h3 {
        color: #1a1a2e;
    }
    body.light-theme .btn-secondary-hero {
        background: #e1e5e9;
        color: #333;
    }
    body.light-theme .profile-name {
        color: #1a1a2e;
    }
    body.light-theme .profile-avatar {
        background: #e1e5e9;
        color: #6c63ff;
    }

    .theme-toggle {
        position: fixed;
        bottom: 20px;
        right: 20px;
        background: #6c63ff;
        color: white;
        border: none;
        border-radius: 50%;
        width: 50px;
        height: 50px;
        font-size: 24px;
        cursor: pointer;
        box-shadow: 0 4px 12px rgba(108, 99, 255, 0.3);
        transition: 0.3s;
        z-index: 999;
    }
    .theme-toggle:hover {
        transform: scale(1.1);
    }

    @media (max-width: 600px) {
        .info-bar {
            flex-direction: column;
            align-items: center;
        }
        .stats-grid {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>

<div class="hero">
    <h1>Selamat Datang di <span>Xyroo Api's</span></h1>
    <p>Platform API REST yang andal, skalabel, dan ramah pengembang. Bangun aplikasi luar biasa dengan rangkaian API komprehensif kami.</p>
    
    <% if (!user) { %>
        <div class="hero-buttons">
            <a href="/register" class="btn-primary-hero"><i class="fas fa-rocket"></i> Mulai</a>
            <a href="/doc/get" class="btn-secondary-hero"><i class="fas fa-book"></i> Dokumentasi</a>
            <a href="/login" class="btn-secondary-hero"><i class="fas fa-sign-in-alt"></i> Login</a>
        </div>
    <% } else { %>
        <div class="hero-buttons">
            <a href="/doc/get" class="btn-primary-hero"><i class="fas fa-code"></i> Cek Endpoint</a>
            <a href="/profile" class="btn-secondary-hero"><i class="fas fa-user"></i> Profil Saya</a>
        </div>
    <% } %>
</div>

<div class="info-bar">
    <span><i class="fas fa-server"></i> Uptime: <strong class="uptime-display" id="uptimeDisplay"><%= stats.uptime %></strong></span>
    <span><i class="fas fa-globe-asia"></i> Lokasi: <strong><%= stats.location %></strong></span>
    <span><i class="fas fa-bolt"></i> Kecepatan: <strong><%= stats.speed %></strong></span>
    <span><i class="fas fa-clock"></i> Latency: <strong><%= stats.latency %></strong></span>
    <span><i class="fas fa-code"></i> Total Endpoint: <strong><%= stats.endpoint %></strong></span>
    <span><i class="fas fa-folder"></i> Kategori: <strong><%= stats.totalCategories %></strong></span>
</div>

<% if (user) { %>
    <div class="profile-container">
        <div class="profile-header">
            <div class="profile-avatar">
                <i class="fas fa-user-circle"></i>
            </div>
            <div class="profile-name"><%= user.username || user.email.split('@')[0] %></div>
            <div class="profile-email"><%= user.email %></div>
        </div>
        <div style="display:flex; gap:10px; margin-top:20px;">
            <a href="/doc/get" class="btn-primary-hero" style="flex:1; text-align:center;"><i class="fas fa-eye"></i> Cek Endpoint</a>
            <a href="/profile" class="btn-secondary-hero" style="flex:1; text-align:center;"><i class="fas fa-user"></i> Profil Lengkap</a>
        </div>
    </div>
<% } else { %>
    <div class="stats-grid">
        <div class="stat-card">
            <div class="icon"><i class="fas fa-code"></i></div>
            <div class="number"><%= stats.endpoint %></div>
            <div class="label">Total Endpoint (Real)</div>
        </div>
        <div class="stat-card">
            <div class="icon"><i class="fas fa-folder"></i></div>
            <div class="number"><%= stats.totalCategories %></div>
            <div class="label">Kategori API</div>
        </div>
        <div class="stat-card">
            <div class="icon"><i class="fas fa-globe-asia"></i></div>
            <div class="number"><%= stats.location %></div>
            <div class="label">Lokasi Server (Real)</div>
        </div>
        <div class="stat-card">
            <div class="icon"><i class="fas fa-bolt"></i></div>
            <div class="number"><%= stats.speed %></div>
            <div class="label">Kecepatan Server (Real)</div>
        </div>
        <div class="stat-card">
            <div class="icon"><i class="fas fa-clock"></i></div>
            <div class="number"><%= stats.latency %></div>
            <div class="label">Latency (Real)</div>
        </div>
        <div class="stat-card">
            <div class="icon"><i class="fas fa-server"></i></div>
            <div class="number"><%= stats.provider %></div>
            <div class="label">Penyedia API</div>
        </div>
    </div>

    <h3 style="color:#f0f6fc; text-align:center; margin: 30px 0 20px;">Mengapa Memilih Xyroo Api's?</h3>
    <div class="features">
        <div class="feature-card">
            <i class="fas fa-bolt"></i>
            <h3>Secepat Kilat</h3>
            <p>Respons cepat dengan server optimal.</p>
        </div>
        <div class="feature-card">
            <i class="fas fa-shield-alt"></i>
            <h3>Keamanan Perusahaan</h3>
            <p>Data Anda aman dengan enkripsi.</p>
        </div>
        <div class="feature-card">
            <i class="fas fa-code"></i>
            <h3>Pengembang Utama</h3>
            <p>Dokumentasi lengkap dan mudah.</p>
        </div>
    </div>
<% } %>

<script>
    function updateUptime() {
        fetch('/api/server-info')
            .then(res => res.json())
            .then(data => {
                if (data.status === 200) {
                    document.getElementById('uptimeDisplay').textContent = data.server.uptime;
                }
            })
            .catch(err => console.error('Uptime error:', err));
    }
    updateUptime();
    setInterval(updateUptime, 5000);
</script>

<%- include('partials/footer') %>