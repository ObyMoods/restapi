<%- include('partials/header') %>

<style>
    /* PROFIL PAGE STYLES */
    .profile-page {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
    }

    .profile-header {
        background: linear-gradient(145deg, #161b22, #0d1117);
        border-radius: 16px;
        padding: 30px;
        text-align: center;
        border: 1px solid #30363d;
        margin-bottom: 20px;
        position: relative;
    }

    .profile-avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 4px solid #6c63ff;
        margin: 0 auto 15px;
        background: #30363d;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 50px;
        color: #6c63ff;
        overflow: hidden;
        cursor: pointer;
        transition: 0.3s;
    }

    .profile-avatar:hover {
        transform: scale(1.05);
        border-color: #58a6ff;
    }

    .profile-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .profile-name {
        font-size: 24px;
        color: #f0f6fc;
        font-weight: bold;
    }

    .profile-email {
        color: #8b949e;
        font-size: 16px;
    }

    .profile-badges {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-top: 10px;
        flex-wrap: wrap;
    }

    .badge-role {
        background: #1f6feb;
        color: white;
        padding: 4px 16px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: bold;
    }

    .badge-verified {
        background: #238636;
        color: white;
        padding: 4px 16px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: bold;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 15px;
        margin-bottom: 20px;
    }

    .info-card {
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: 12px;
        padding: 20px;
        transition: 0.3s;
    }

    .info-card:hover {
        border-color: #58a6ff;
        transform: translateY(-2px);
    }

    .info-card .label {
        color: #8b949e;
        font-size: 13px;
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .info-card .value {
        color: #f0f6fc;
        font-size: 18px;
        font-weight: bold;
    }

    .info-card .value small {
        font-size: 14px;
        font-weight: normal;
        color: #8b949e;
    }

    .limit-section {
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
    }

    .limit-header {
        display: flex;
        justify-content: space-between;
        color: #8b949e;
        font-size: 14px;
        margin-bottom: 8px;
    }

    .limit-bar {
        background: #30363d;
        border-radius: 10px;
        height: 10px;
        overflow: hidden;
    }

    .limit-bar .fill {
        height: 100%;
        background: linear-gradient(90deg, #6c63ff, #58a6ff);
        border-radius: 10px;
        transition: width 0.5s ease;
    }

    .action-buttons {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 10px;
        margin-top: 20px;
    }

    .btn-action {
        padding: 12px;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-decoration: none;
    }

    .btn-primary-action {
        background: #6c63ff;
        color: white;
    }

    .btn-primary-action:hover {
        background: #5a52d5;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(108, 99, 255, 0.3);
    }

    .btn-secondary-action {
        background: #30363d;
        color: #c9d1d9;
    }

    .btn-secondary-action:hover {
        background: #484f58;
    }

    .btn-success-action {
        background: #238636;
        color: white;
    }

    .btn-success-action:hover {
        background: #1a7a2e;
    }

    .btn-danger-action {
        background: #da3633;
        color: white;
    }

    .btn-danger-action:hover {
        background: #b92d2a;
    }

    .btn-warning-action {
        background: #d29922;
        color: white;
    }

    .btn-warning-action:hover {
        background: #b8860b;
    }

    /* EDIT PROFILE MODAL */
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.7);
        z-index: 9999;
        justify-content: center;
        align-items: center;
    }

    .modal-overlay.show {
        display: flex;
    }

    .modal-box {
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: 16px;
        padding: 30px;
        max-width: 450px;
        width: 90%;
    }

    .modal-box h3 {
        color: #f0f6fc;
        margin-bottom: 15px;
    }

    .modal-box input {
        width: 100%;
        padding: 12px;
        background: #0d1117;
        border: 1px solid #30363d;
        border-radius: 8px;
        color: #c9d1d9;
        margin-bottom: 15px;
        outline: none;
    }

    .modal-box input:focus {
        border-color: #58a6ff;
    }

    .modal-box .modal-actions {
        display: flex;
        gap: 10px;
    }

    .modal-box .modal-actions button {
        flex: 1;
        padding: 10px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
    }

    .modal-box .modal-actions .btn-save {
        background: #6c63ff;
        color: white;
    }

    .modal-box .modal-actions .btn-save:hover {
        background: #5a52d5;
    }

    .modal-box .modal-actions .btn-cancel {
        background: #30363d;
        color: #c9d1d9;
    }

    .modal-box .modal-actions .btn-cancel:hover {
        background: #484f58;
    }

    /* UPTIME DISPLAY */
    .uptime-display {
        font-family: 'Consolas', monospace;
        color: #58a6ff;
    }

    /* LIGHT THEME OVERRIDES */
    body.light-theme {
        background: #f0f2f5;
        color: #1a1a2e;
    }
    body.light-theme .profile-header {
        background: white;
        border-color: #e1e5e9;
    }
    body.light-theme .profile-name {
        color: #1a1a2e;
    }
    body.light-theme .info-card {
        background: white;
        border-color: #e1e5e9;
    }
    body.light-theme .info-card .value {
        color: #1a1a2e;
    }
    body.light-theme .limit-section {
        background: white;
        border-color: #e1e5e9;
    }
    body.light-theme .btn-secondary-action {
        background: #e1e5e9;
        color: #333;
    }
    body.light-theme .modal-box {
        background: white;
        border-color: #e1e5e9;
    }
    body.light-theme .modal-box h3 {
        color: #1a1a2e;
    }
    body.light-theme .modal-box input {
        background: #f8f9fa;
        color: #1a1a2e;
        border-color: #e1e5e9;
    }
    body.light-theme .modal-box .modal-actions .btn-cancel {
        background: #e1e5e9;
        color: #333;
    }
    body.light-theme .profile-avatar {
        background: #e1e5e9;
        color: #6c63ff;
    }

    /* THEME TOGGLE */
    .theme-toggle {
        position: fixed;
        bottom: 20px;
        right: 20px;
        background: #6c63ff;
        color: white;
        border: none;
        border-radius: 50%;
        width: 50px;
        height: 50px;
        font-size: 24px;
        cursor: pointer;
        box-shadow: 0 4px 12px rgba(108, 99, 255, 0.3);
        transition: 0.3s;
        z-index: 999;
    }
    .theme-toggle:hover {
        transform: scale(1.1);
    }

    /* Responsive */
    @media (max-width: 600px) {
        .profile-page {
            padding: 10px;
        }
        .info-grid {
            grid-template-columns: 1fr;
        }
        .action-buttons {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>

<div class="profile-page">
    <!-- HEADER PROFIL -->
    <div class="profile-header">
        <div class="profile-avatar" onclick="openEditProfile()">
            <% if (user.avatar) { %>
                <img src="<%= user.avatar %>" alt="Avatar">
            <% } else { %>
                <i class="fas fa-user-circle"></i>
            <% } %>
        </div>
        <div class="profile-name"><%= user.username || user.email.split('@')[0] %></div>
        <div class="profile-email"><%= user.email %></div>
        <div class="profile-badges">
            <span class="badge-role"><%= user.role %></span>
            <span class="badge-verified"><i class="fas fa-check-circle"></i> Verified</span>
        </div>
    </div>

    <!-- INFO GRID -->
    <div class="info-grid">
        <div class="info-card">
            <div class="label"><i class="fas fa-envelope"></i> Email</div>
            <div class="value"><%= user.email %></div>
        </div>
        <div class="info-card">
            <div class="label"><i class="fas fa-key"></i> API Key</div>
            <div class="value" style="font-size:14px; word-break:break-all;">
                <%= user.apiKey %>
                <button onclick="resetApiKey()" style="background:none; border:none; color:#58a6ff; cursor:pointer; margin-left:10px;">
                    <i class="fas fa-sync" title="Reset API Key"></i>
                </button>
            </div>
        </div>
        <div class="info-card">
            <div class="label"><i class="fas fa-calendar"></i> Terdaftar</div>
            <div class="value"><%= user.registeredAt %></div>
        </div>
        <div class="info-card">
            <div class="label"><i class="fas fa-clock"></i> Uptime Server</div>
            <div class="value uptime-display" id="uptimeDisplay">Loading...</div>
        </div>
        <div class="info-card">
            <div class="label"><i class="fas fa-globe-asia"></i> Lokasi Server</div>
            <div class="value"><%= stats.location %></div>
        </div>
        <div class="info-card">
            <div class="label"><i class="fas fa-server"></i> Total Endpoint</div>
            <div class="value"><%= stats.endpoint %></div>
        </div>
    </div>

    <!-- LIMIT SECTION -->
    <div class="limit-section">
        <div class="limit-header">
            <span>Penggunaan Limit</span>
            <span><%= user.used %> / <%= user.limit %></span>
        </div>
        <div class="limit-bar">
            <div class="fill" style="width: <%= Math.round((user.used / user.limit) * 100) %>%;"></div>
        </div>
        <div style="text-align:right; font-size:12px; color:#8b949e; margin-top:5px;">
            <%= Math.round((user.used / user.limit) * 100) %>% digunakan
        </div>
    </div>

    <!-- ACTION BUTTONS -->
    <div class="action-buttons">
        <button class="btn-action btn-primary-action" onclick="openEditProfile()">
            <i class="fas fa-edit"></i> Edit Profil
        </button>
        <button class="btn-action btn-success-action" onclick="refreshData()">
            <i class="fas fa-sync"></i> Refresh Data
        </button>
        <a href="/doc/get" class="btn-action btn-secondary-action">
            <i class="fas fa-code"></i> Cek Endpoint
        </a>
        <a href="/logout" class="btn-action btn-danger-action">
            <i class="fas fa-sign-out-alt"></i> Logout
        </a>
    </div>
</div>

<!-- EDIT PROFILE MODAL -->
<div class="modal-overlay" id="editModal">
    <div class="modal-box">
        <h3><i class="fas fa-edit"></i> Edit Profil</h3>
        <p style="color:#8b949e; font-size:14px; margin-bottom:15px;">Ubah username dan avatar Anda.</p>
        
        <label style="color:#8b949e; font-size:13px;">Username</label>
        <input type="text" id="editUsername" value="<%= user.username || user.email.split('@')[0] %>" placeholder="Username baru">
        
        <label style="color:#8b949e; font-size:13px;">Avatar URL</label>
        <input type="text" id="editAvatar" value="<%= user.avatar || '' %>" placeholder="https://example.com/avatar.jpg">
        
        <div class="modal-actions">
            <button class="btn-save" onclick="saveProfile()">Simpan</button>
            <button class="btn-cancel" onclick="closeEditProfile()">Batal</button>
        </div>
    </div>
</div>

<!-- THEME TOGGLE BUTTON -->
<button class="theme-toggle" onclick="toggleTheme()" title="Ganti Tema">
    <i class="fas fa-moon" id="themeIcon"></i>
</button>

<script>
    // ==================== UPTIME REAL-TIME ====================
    function updateUptime() {
        fetch('/api/server-info')
            .then(res => res.json())
            .then(data => {
                if (data.status === 200) {
                    document.getElementById('uptimeDisplay').textContent = data.server.uptime;
                }
            })
            .catch(err => {
                console.error('Uptime error:', err);
            });
    }
    updateUptime();
    setInterval(updateUptime, 5000);

    // ==================== EDIT PROFILE ====================
    function openEditProfile() {
        document.getElementById('editModal').classList.add('show');
    }

    function closeEditProfile() {
        document.getElementById('editModal').classList.remove('show');
    }

    function saveProfile() {
        const username = document.getElementById('editUsername').value.trim();
        const avatar = document.getElementById('editAvatar').value.trim();
        
        if (!username) {
            alert('Username tidak boleh kosong!');
            return;
        }

        fetch('/profile/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username: username, avatar: avatar })
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                location.reload();
            } else {
                alert(data.message);
            }
        })
        .catch(err => {
            alert('Terjadi kesalahan: ' + err.message);
        });
    }

    // ==================== RESET API KEY ====================
    function resetApiKey() {
        if (!confirm('Apakah Anda yakin ingin mereset API Key? Limit Anda akan tetap sama.')) {
            return;
        }

        fetch('/profile/reset-key', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                alert(data.message + '\nAPI Key baru: ' + data.newApiKey);
                location.reload();
            } else {
                alert(data.message);
            }
        })
        .catch(err => {
            alert('Terjadi kesalahan: ' + err.message);
        });
    }

    // ==================== REFRESH DATA ====================
    function refreshData() {
        const btn = event.target;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Refreshing...';
        btn.disabled = true;
        setTimeout(() => {
            location.reload();
        }, 1000);
    }

    // ==================== THEME TOGGLE ====================
    function toggleTheme() {
        const body = document.body;
        const icon = document.getElementById('themeIcon');
        
        if (body.classList.contains('light-theme')) {
            body.classList.remove('light-theme');
            icon.className = 'fas fa-moon';
            localStorage.setItem('theme', 'dark');
        } else {
            body.classList.add('light-theme');
            icon.className = 'fas fa-sun';
            localStorage.setItem('theme', 'light');
        }
    }

    // Load saved theme
    document.addEventListener('DOMContentLoaded', function() {
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'light') {
            document.body.classList.add('light-theme');
            document.getElementById('themeIcon').className = 'fas fa-sun';
        }
    });
</script>

<%- include('partials/footer') %>