<%- include('partials/header') %>

<style>
    .api-card {
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 25px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.3);
        transition: 0.3s;
        position: relative;
    }
    .api-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, #6c63ff, #58a6ff);
        border-radius: 12px 12px 0 0;
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }
    .card-title {
        font-size: 18px;
        font-weight: bold;
        color: #f0f6fc;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .card-title i { color: #58a6ff; }
    .badge-json {
        background: #1f6feb;
        color: white;
        padding: 4px 14px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: bold;
    }
    .status-badge {
        background: #238636;
        color: white;
        padding: 2px 12px;
        border-radius: 12px;
        font-size: 11px;
        margin-left: 10px;
    }

    .endpoint-bar {
        background: #0d1117;
        padding: 10px 15px;
        border-radius: 8px;
        margin: 10px 0;
        border: 1px solid #30363d;
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
    }
    .method-tag {
        background: #238636;
        color: white;
        padding: 4px 12px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: bold;
        font-family: monospace;
    }
    .endpoint-path {
        font-family: 'Consolas', monospace;
        color: #f0f6fc;
        font-size: 14px;
        word-break: break-all;
    }
    .copy-endpoint {
        margin-left: auto;
        background: none;
        border: none;
        color: #8b949e;
        cursor: pointer;
    }
    .copy-endpoint:hover { color: #58a6ff; }

    .param-section {
        margin: 15px 0;
    }
    .param-title {
        font-size: 14px;
        font-weight: bold;
        color: #f0f6fc;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .param-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }
    .param-table th {
        text-align: left;
        color: #8b949e;
        padding: 8px 10px;
        border-bottom: 1px solid #30363d;
    }
    .param-table td {
        padding: 10px;
        border-bottom: 1px solid #21262d;
        color: #c9d1d9;
    }
    .param-table tr:last-child td { border-bottom: none; }
    .param-name {
        background: #30363d;
        padding: 2px 8px;
        border-radius: 4px;
        font-family: monospace;
        font-size: 13px;
        color: #f0f6fc;
        display: inline-block;
    }

    .code-block {
        background: #0d1117;
        padding: 15px;
        border-radius: 8px;
        font-family: 'Consolas', monospace;
        font-size: 13px;
        color: #c9d1d9;
        overflow-x: auto;
        position: relative;
        border: 1px solid #30363d;
        margin: 10px 0;
    }
    .code-block .copy-code {
        position: absolute;
        top: 8px;
        right: 8px;
        background: #30363d;
        border: none;
        color: #c9d1d9;
        padding: 4px 10px;
        border-radius: 4px;
        cursor: pointer;
        font-size: 11px;
    }
    .code-block .copy-code:hover { background: #484f58; }

    .test-section {
        margin: 15px 0;
        background: #0d1117;
        padding: 15px;
        border-radius: 8px;
        border: 1px solid #30363d;
    }
    .test-section label {
        display: block;
        margin-bottom: 5px;
        color: #8b949e;
        font-size: 13px;
    }
    .test-section input {
        width: 100%;
        padding: 10px;
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: 6px;
        color: #c9d1d9;
        margin-bottom: 10px;
        outline: none;
    }
    .test-section input:focus { border-color: #58a6ff; }
    .btn-test {
        background: #6c63ff;
        color: white;
        border: none;
        padding: 8px 25px;
        border-radius: 6px;
        font-size: 14px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .btn-test:hover { background: #5a52d5; }
    .btn-test:disabled { opacity: 0.5; cursor: not-allowed; }

    .result-box {
        display: none;
        margin-top: 15px;
        background: #0d1117;
        border: 1px solid #30363d;
        border-radius: 8px;
        padding: 15px;
    }
    .result-box pre {
        margin: 0;
        white-space: pre-wrap;
        word-break: break-all;
        color: #c9d1d9;
        font-family: 'Consolas', monospace;
        font-size: 13px;
    }
    .result-box .status-ok {
        color: #238636;
        font-weight: bold;
        margin-bottom: 5px;
        display: block;
    }

    .toggle-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        user-select: none;
        padding: 5px 0;
    }
    .toggle-header .toggle-icon {
        color: #8b949e;
        font-size: 16px;
        transition: 0.3s;
    }
    .toggle-header .toggle-icon.rotated {
        transform: rotate(180deg);
    }
    .card-content {
        transition: 0.3s;
    }
    .card-content.hidden {
        display: none;
    }

    .search-container {
        margin-bottom: 20px;
        display: flex;
        gap: 10px;
    }
    .search-container input {
        flex: 1;
        padding: 12px 15px;
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: 8px;
        color: #c9d1d9;
        font-size: 14px;
        outline: none;
    }
    .search-container input:focus {
        border-color: #58a6ff;
    }
    .search-container input::placeholder {
        color: #8b949e;
    }
    .search-container button {
        padding: 12px 20px;
        background: #6c63ff;
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 14px;
    }
    .search-container button:hover {
        background: #5a52d5;
    }

    .no-result {
        text-align: center;
        padding: 40px;
        color: #8b949e;
        display: none;
    }
    .no-result i {
        font-size: 50px;
        margin-bottom: 15px;
        display: block;
    }

    body.light-theme {
        background: #f0f2f5;
        color: #1a1a2e;
    }
    body.light-theme .api-card {
        background: white;
        border-color: #e1e5e9;
    }
    body.light-theme .card-title {
        color: #1a1a2e;
    }
    body.light-theme .endpoint-bar {
        background: #f8f9fa;
        border-color: #e1e5e9;
    }
    body.light-theme .endpoint-path {
        color: #1a1a2e;
    }
    body.light-theme .param-table td {
        color: #1a1a2e;
    }
    body.light-theme .code-block {
        background: #f8f9fa;
        color: #333;
        border-color: #e1e5e9;
    }
    body.light-theme .test-section {
        background: #f8f9fa;
        border-color: #e1e5e9;
    }
    body.light-theme .test-section input {
        background: white;
        color: #1a1a2e;
        border-color: #e1e5e9;
    }
    body.light-theme .result-box {
        background: #f8f9fa;
        border-color: #e1e5e9;
    }
    body.light-theme .result-box pre {
        color: #1a1a2e;
    }
    body.light-theme .param-name {
        background: #e1e5e9;
        color: #1a1a2e;
    }
    body.light-theme .search-container input {
        background: white;
        color: #1a1a2e;
        border-color: #e1e5e9;
    }

    .theme-toggle {
        position: fixed;
        bottom: 20px;
        right: 20px;
        background: #6c63ff;
        color: white;
        border: none;
        border-radius: 50%;
        width: 50px;
        height: 50px;
        font-size: 24px;
        cursor: pointer;
        box-shadow: 0 4px 12px rgba(108, 99, 255, 0.3);
        transition: 0.3s;
        z-index: 999;
    }
    .theme-toggle:hover {
        transform: scale(1.1);
    }

    @media (max-width: 600px) {
        .endpoint-bar { flex-direction: column; align-items: flex-start; }
        .copy-endpoint { margin-left: 0; }
        .search-container { flex-direction: column; }
    }
</style>

<div style="text-align: center; margin-bottom: 30px;">
    <h2 style="color: #f0f6fc;">Dokumentasi Endpoint API</h2>
    <p style="color: #8b949e;">Jelajahi berbagai endpoint API yang tersedia</p>
</div>

<div class="search-container">
    <input type="text" id="searchInput" placeholder="Cari endpoint..." onkeyup="searchEndpoint()">
    <button onclick="searchEndpoint()"><i class="fas fa-search"></i> Cari</button>
</div>

<div class="no-result" id="noResult">
    <i class="fas fa-search"></i>
    <h3>Endpoint tidak ditemukan</h3>
    <p>Coba gunakan kata kunci lain</p>
</div>

<% apiList.forEach((api, index) => { %>
    <div class="api-card search-item" id="card-<%= index %>" data-name="<%= api.name.toLowerCase() %>" data-endpoint="<%= api.endpoint.toLowerCase() %>" data-category="<%= api.category.toLowerCase() %>">
        <div class="card-header">
            <div class="card-title">
                <i class="fas fa-code"></i> <%= api.name %>
                <span class="status-badge">SIAP</span>
            </div>
            <span class="badge-json">JSON</span>
        </div>

        <div class="toggle-header" onclick="toggleCard(<%= index %>)">
            <span style="color:#8b949e; font-size:13px;">
                <i class="fas fa-chevron-down"></i> Tampilkan Detail
            </span>
            <span class="toggle-icon" id="toggleIcon-<%= index %>">▼</span>
        </div>

        <div class="card-content hidden" id="cardContent-<%= index %>">
            <div class="endpoint-bar">
                <span class="method-tag"><%= api.method %></span>
                <span class="endpoint-path"><%= api.endpoint %></span>
                <button class="copy-endpoint" onclick="copyEndpoint('<%= api.endpoint %>')">
                    <i class="fas fa-copy"></i>
                </button>
            </div>

            <div class="param-section">
                <div class="param-title">
                    <i class="fas fa-list"></i> Parameter
                </div>
                <table class="param-table">
                    <thead>
                        <tr>
                            <th>Parameter</th>
                            <th>Deskripsi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="param-name">apikey</span></td>
                            <td>Kunci API untuk autentikasi (6 huruf)</td>
                        </tr>
                        <tr>
                            <td><span class="param-name">query</span></td>
                            <td>Parameter opsional untuk query tambahan</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="code-block">
                <button class="copy-code" onclick="copyCode(this)">Salin</button>
                <span style="color:#f0f6fc;">const apikey = </span><span style="color:#a5d6ff;">'<%= user ? user.apiKey : 'YOUR_API_KEY' %>'</span><span style="color:#c9d1d9;">;</span>
                <br><br>
                <span style="color:#f0f6fc;">fetch</span>(<span style="color:#a5d6ff;">`<%= BASE_URL %><%= api.endpoint %>?apikey=${apikey}`</span>)
                <br>
                <span style="color:#c9d1d9;">.then(res => res.json())</span>
                <br>
                <span style="color:#c9d1d9;">.then(data => console.log(data));</span>
            </div>

            <div class="test-section">
                <label><i class="fas fa-flask"></i> Uji API</label>
                <input type="text" id="input-apikey-<%= index %>" value="<%= user ? user.apiKey : 'YOUR_API_KEY' %>" placeholder="apikey">
                <input type="text" id="input-query-<%= index %>" placeholder="query (opsional)">
                <button class="btn-test" onclick="testAPI('<%= api.endpoint %>', <%= index %>, this)">
                    <i class="fas fa-play"></i> Uji API
                </button>
            </div>

            <div class="result-box" id="result-<%= index %>">
                <span class="status-ok">✓ 200 OK</span>
                <pre id="result-content-<%= index %>">Menunggu data...</pre>
            </div>
        </div>
    </div>
<% }) %>

<!-- CARD TIKTOK STALK -->
<div class="api-card search-item" id="card-tiktok" data-name="tiktok stalk" data-endpoint="/api/stalk/tiktok" data-category="ai">
    <div class="card-header">
        <div class="card-title">
            <i class="fab fa-tiktok"></i> TIKTOK STALK
            <span class="status-badge">SIAP</span>
        </div>
        <span class="badge-json">JSON</span>
    </div>

    <div class="toggle-header" onclick="toggleCard('tiktok')">
        <span style="color:#8b949e; font-size:13px;">
            <i class="fas fa-chevron-down"></i> Tampilkan Detail
        </span>
        <span class="toggle-icon" id="toggleIcon-tiktok">▼</span>
    </div>

    <div class="card-content hidden" id="cardContent-tiktok">
        <div class="endpoint-bar">
            <span class="method-tag">GET</span>
            <span class="endpoint-path">/api/stalk/tiktok?username=&apikey=</span>
            <button class="copy-endpoint" onclick="copyEndpoint('/api/stalk/tiktok')">
                <i class="fas fa-copy"></i>
            </button>
        </div>

        <div class="param-section">
            <div class="param-title"><i class="fas fa-list"></i> Parameter</div>
            <table class="param-table">
                <thead>
                    <tr><th>Parameter</th><th>Deskripsi</th></tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="param-name">username</span></td>
                        <td>Nama pengguna TikTok (tanpa @)</td>
                    </tr>
                    <tr>
                        <td><span class="param-name">apikey</span></td>
                        <td>Kunci API untuk autentikasi (6 huruf)</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="code-block">
            <button class="copy-code" onclick="copyCode(this)">Salin</button>
            <span style="color:#f0f6fc;">const apikey = </span><span style="color:#a5d6ff;">'<%= user ? user.apiKey : 'YOUR_API_KEY' %>'</span><span style="color:#c9d1d9;">;</span>
            <br><br>
            <span style="color:#f0f6fc;">fetch</span>(<span style="color:#a5d6ff;">`<%= BASE_URL %>/api/stalk/tiktok?username=jessicalove&apikey=${apikey}`</span>)
            <br>
            <span style="color:#c9d1d9;">.then(res => res.json())</span>
            <br>
            <span style="color:#c9d1d9;">.then(data => console.log(data));</span>
        </div>

        <div class="test-section">
            <label><i class="fas fa-flask"></i> Uji API TikTok</label>
            <input type="text" id="input-username-tiktok" value="jessicalove" placeholder="Username TikTok">
            <input type="text" id="input-apikey-tiktok" value="<%= user ? user.apiKey : 'YOUR_API_KEY' %>" placeholder="apikey">
            <button class="btn-test" onclick="testTikTok(this)">
                <i class="fas fa-play"></i> Uji API
            </button>
        </div>

        <div class="result-box" id="result-tiktok">
            <span class="status-ok">✓ 200 OK</span>
            <pre id="result-content-tiktok">Menunggu data TikTok...</pre>
        </div>
    </div>
</div>

<button class="theme-toggle" onclick="toggleTheme()" title="Ganti Tema">
    <i class="fas fa-moon" id="themeIcon"></i>
</button>

<script>
    function searchEndpoint() {
        const input = document.getElementById('searchInput').value.toLowerCase();
        const items = document.querySelectorAll('.search-item');
        const noResult = document.getElementById('noResult');
        let found = false;

        items.forEach(item => {
            const name = item.getAttribute('data-name');
            const endpoint = item.getAttribute('data-endpoint');
            const category = item.getAttribute('data-category');

            if (name.includes(input) || endpoint.includes(input) || category.includes(input)) {
                item.style.display = 'block';
                found = true;
            } else {
                item.style.display = 'none';
            }
        });

        noResult.style.display = found ? 'none' : 'block';
    }

    function toggleCard(id) {
        const content = document.getElementById(`cardContent-${id}`);
        const icon = document.getElementById(`toggleIcon-${id}`);
        
        content.classList.toggle('hidden');
        icon.classList.toggle('rotated');
    }

    function copyEndpoint(endpoint) {
        navigator.clipboard.writeText(endpoint).then(() => {
            const btn = event.target.closest('button');
            btn.innerHTML = '<i class="fas fa-check" style="color:#238636;"></i>';
            setTimeout(() => btn.innerHTML = '<i class="fas fa-copy"></i>', 1500);
        });
    }

    function copyCode(btn) {
        const code = btn.parentElement.textContent.replace('Salin', '').trim();
        navigator.clipboard.writeText(code).then(() => {
            btn.textContent = '✓ Disalin';
            setTimeout(() => btn.textContent = 'Salin', 1500);
        });
    }

    function testAPI(endpoint, index, btn) {
        const apikey = document.getElementById(`input-apikey-${index}`).value;
        const query = document.getElementById(`input-query-${index}`).value;
        const resultBox = document.getElementById(`result-${index}`);
        const resultContent = document.getElementById(`result-content-${index}`);

        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Loading...';
        resultBox.style.display = 'block';
        resultContent.textContent = 'Mengambil data...';

        let url = `${BASE_URL}${endpoint}?apikey=${apikey}`;
        if (query) url += `&query=${encodeURIComponent(query)}`;

        fetch(url)
            .then(res => res.json())
            .then(data => {
                resultContent.textContent = JSON.stringify(data, null, 2);
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-play"></i> Uji API';
            })
            .catch(err => {
                resultContent.textContent = 'Error: ' + err.message;
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-play"></i> Uji API';
            });
    }

    function testTikTok(btn) {
        const username = document.getElementById('input-username-tiktok').value;
        const apikey = document.getElementById('input-apikey-tiktok').value;
        const resultBox = document.getElementById('result-tiktok');
        const resultContent = document.getElementById('result-content-tiktok');

        if (!username) {
            resultBox.style.display = 'block';
            resultContent.textContent = 'Error: Username tidak boleh kosong';
            return;
        }

        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Mencari...';
        resultBox.style.display = 'block';
        resultContent.textContent = `Mencari user @${username} ...`;

        fetch(`${BASE_URL}/api/stalk/tiktok?username=${encodeURIComponent(username)}&apikey=${apikey}`)
            .then(res => res.json())
            .then(data => {
                resultContent.textContent = JSON.stringify(data, null, 2);
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-play"></i> Uji API';
            })
            .catch(err => {
                resultContent.textContent = 'Error: ' + err.message;
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-play"></i> Uji API';
            });
    }

    function toggleTheme() {
        const body = document.body;
        const icon = document.getElementById('themeIcon');
        
        if (body.classList.contains('light-theme')) {
            body.classList.remove('light-theme');
            icon.className = 'fas fa-moon';
            localStorage.setItem('theme', 'dark');
        } else {
            body.classList.add('light-theme');
            icon.className = 'fas fa-sun';
            localStorage.setItem('theme', 'light');
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'light') {
            document.body.classList.add('light-theme');
            document.getElementById('themeIcon').className = 'fas fa-sun';
        }
    });
</script>

<%- include('partials/footer') %>